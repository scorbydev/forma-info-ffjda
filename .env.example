# OpenRouter optionnel pour atelier OCR
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen2.5-vl-32b-instruct:free

# Hugging Face fallback API pour atelier OCR
HF_API_TOKEN=
HF_MODEL_ID=

# Provider par defaut pour l'atelier OCR : sample, openrouter ou huggingface
OCR_PROVIDER=sample

# Nombre maximum de pages PDF envoyees au provider vision OpenRouter
OCR_MAX_PAGES=2
